# miSchedule バックエンド環境変数
# .env.example を .env にコピーして値を設定してください

# PostgreSQL 接続URL（必須）
# 例: postgres://user:password@localhost:5432/miSchedule?sslmode=disable
DATABASE_URL=postgres://misched:your-password@postgres:5432/miSchedule?sslmode=disable

# JWT アクセストークン署名用シークレット（必須）
# 十分に長いランダム文字列を設定してください
JWT_SECRET=change-me-to-a-random-string

# JWT リフレッシュトークン署名用シークレット（必須）
# JWT_SECRET とは異なる値を設定してください
JWT_REFRESH_SECRET=change-me-to-another-random-string

# Misskey アクセストークン暗号化キー（必須）
# 正確に32バイトの文字列を設定してください
ENCRYPTION_KEY=change-me-to-exactly-32-bytes!!

# CORS で許可するフロントエンドのオリジン（必須）
# Netlify などフロントエンドのURLをカンマ区切りで指定
ALLOWED_ORIGINS=https://your-app.netlify.app

# ログインを許可するMisskeyインスタンス（必須）
# ホスト名をカンマ区切りで指定
# 例: summary.ink,misskey.io
ALLOWED_INSTANCES=summary.ink

# Dockerコンテナ内からホストのMisskeyに接続するためのマッピング（任意）
# Docker開発環境でのみ必要です
# HOST_RESOLVE_MAP=http://localhost:3000=http://host.docker.internal:3000

# 通知チェック間隔（秒）（任意、デフォルト: 60）
NOTIFICATION_INTERVAL=60

# ログレベル（任意、debug/info、デフォルト: info）
LOG_LEVEL=info

# サーバーポート（任意、デフォルト: 8080）
PORT=8080
